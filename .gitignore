__pycache__/

# Auth tokens — never commit
data/trakt_auth.json
data/.token_refresh_result

# Large intermediate caches — persisted via actions/cache, NOT git
# These are 30MB+ total, rebuilt each run from TMDB/Trakt APIs
data/people.json
data/season_credits.json
data/entries_cache.json
data/other_crew.json
data/directors.json
data/writers.json
data/studios.json
data/crew_episodes.json
data/visible_priority.json
data/migration_candidates.json
# NOTE: Small lookup caches (tmdb_credits_done, tmdb_trakt_cache, etc.)
# stay in git — they're tiny (<200KB each) and critical for build speed.
# headshots.json, posters.json, logos.json also stay in git (accumulated data).

# Environment and secrets
.env
.env.*
*.pem
*.key

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
