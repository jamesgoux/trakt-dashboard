data/lb_tmdb_cache.json
data/slug_recency.json
data/slug_tmdb.json
data/visible_priority.json
data/migration_candidates.json
# NOTE: headshots.json, posters.json, logos.json are NOT gitignored —
# they accumulate over many runs and can't be rebuilt quickly

